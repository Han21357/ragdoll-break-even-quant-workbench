# 老布偶猫回本之路 · 环境变量配置模板
# 复制本文件为 .env，填入真实值后使用

# ===== LLM 配置（必填）=====
# TokenHub OpenAI 兼容接口
TOKENHUB_API_KEY=your_tokenhub_api_key_here
TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TOKENHUB_MODEL=deepseek-v4-pro

# LLM 调用超时（秒）
LLM_TIMEOUT_SECONDS=25

# ===== TradingAgents 配置（选填，仅 7 角色 Agent 需要）=====
# TradingAgents 通过 OPENAI_API_KEY + OPENAI_BASE_URL 调用 LLM
# 值和 TOKENHUB_* 一样，只是变量名不同
# OPENAI_API_KEY=your_tokenhub_api_key_here
# OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1

# ===== 数据源（无需配置）=====
# baostock 免费无限制，不需要 API key
# wyckoff CLI 需单独安装：pip install youngcan-wyckoff-analysis
