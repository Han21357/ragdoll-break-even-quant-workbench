HOST=127.0.0.1
PORT=8766
RAGDOLL_ALLOWED_ORIGINS=http://localhost:8766,http://127.0.0.1:8766
RAGDOLL_DATA_DIR=.ragdoll_data
RAGDOLL_CACHE_DIR=.ragdoll_data/cache
AKTOOLS_URL=
TUSHARE_TOKEN=
RAGDOLL_DB_PATH=.ragdoll_data/ragdoll.sqlite3
# Isolated public showcase mode: skips legacy imports and disables private LLM credentials.
RAGDOLL_PUBLIC_DEMO=0

# Optional LLM endpoint for AI explanation; never exposed to frontend.
TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TOKENHUB_API_KEY=
TOKENHUB_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=90

# Alternative OpenAI-compatible Tencent Hunyuan configuration.
HUNYUAN_BASE_URL=
HUNYUAN_API_KEY=
HUNYUAN_MODEL=

# Optional external CLI. Leave empty when not installed.
WYCKOFF_BIN=
PYTHON_BIN=
